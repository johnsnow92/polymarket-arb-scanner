# Kalshi API key authentication (required for cross-platform scanning)
KALSHI_API_KEY_ID=your_api_key_id
KALSHI_PRIVATE_KEY_PATH=~/path/to/kalshi-private-key.pem

# Polymarket wallet credentials (required for trade execution)
POLYMARKET_PRIVATE_KEY=your_polygon_wallet_private_key
POLYMARKET_CHAIN_ID=137

# Optional: minimum profit threshold (default: 0.005 = 0.5%)
# MIN_PROFIT_THRESHOLD=0.005

# Execution settings
MAX_TRADE_SIZE=5.00
DAILY_LOSS_LIMIT=25.00
MAX_OPEN_POSITIONS=10
MIN_LIQUIDITY=50.0
MIN_NET_ROI=0.01
EXECUTION_MODE=semi-auto
DRY_RUN=true
