# Polymarket Arb Scanner — Environment Variables
# Copy to .env and fill in your values

# ===== Polymarket =====
POLYMARKET_PRIVATE_KEY=        # Ethereum private key for CLOB trading
POLYMARKET_CHAIN_ID=137        # Polygon mainnet (default)

# ===== Kalshi =====
KALSHI_API_KEY_ID=             # Kalshi API key ID
KALSHI_PRIVATE_KEY_PATH=kalshi-private-key.pem  # Path to RSA private key

# ===== PredictIt =====
PREDICTIT_EMAIL=               # PredictIt login email
PREDICTIT_PASSWORD=            # PredictIt login password

# ===== Betfair =====
BETFAIR_USERNAME=              # Betfair username
BETFAIR_PASSWORD=              # Betfair password
BETFAIR_API_KEY=               # Betfair API application key

# ===== Manifold Markets =====
MANIFOLD_API_KEY=              # Manifold API key (from settings page)

# ===== Scanner Configuration =====
MIN_PROFIT_THRESHOLD=0.005     # Minimum net profit threshold (0.5%)
FUZZY_MATCH_THRESHOLD=80       # Cross-platform title match threshold
WS_SUBSCRIPTION_LIMIT=100     # Max WebSocket subscriptions per platform
PARALLEL_WORKERS=4             # Parallel API fetch workers
RESCAN_INTERVAL=300            # Seconds between continuous mode re-scans

# ===== Risk Management =====
MAX_TRADE_SIZE=5.0             # Max dollars per trade
DAILY_LOSS_LIMIT=25.0          # Stop trading if daily P&L below -$25
MAX_OPEN_POSITIONS=10          # Max concurrent open positions
MIN_LIQUIDITY=50.0             # Min order book depth (contracts)
MIN_NET_ROI=0.01               # Min net ROI to execute (1%)

# ===== Execution =====
DRY_RUN=true                   # Set to false for live trading
EXECUTION_MODE=semi-auto       # semi-auto (confirm each) or full-auto

# ===== Proxy =====
POLYMARKET_PROXY_URL=          # e.g. socks5://127.0.0.1:1080
KALSHI_PROXY_URL=              # e.g. http://127.0.0.1:8080

# ===== Rate Limits =====
PM_RATE_LIMIT=0.1              # Seconds between Polymarket requests
KALSHI_RATE_LIMIT=0.15         # Seconds between Kalshi requests
KALSHI_FEE_CAP_CENTS=175       # Kalshi fee cap in cents
