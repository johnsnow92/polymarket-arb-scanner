# Polymarket Arb Scanner — Environment Variables
# Copy to .env and fill in values. All have sensible defaults in config.py.

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=

# ---------------------------------------------------------------------------
# Scanner Tuning
# ---------------------------------------------------------------------------
MIN_PROFIT_THRESHOLD=0.005
FUZZY_MATCH_THRESHOLD=72
RESCAN_INTERVAL=30
PARALLEL_WORKERS=4
MAX_RESOLUTION_DAYS=7

# ---------------------------------------------------------------------------
# Execution
# ---------------------------------------------------------------------------
DRY_RUN=true
EXECUTION_MODE=semi-auto          # semi-auto | full-auto
ENABLED_EXECUTION_PLATFORMS=polymarket,kalshi
BASE_TRADE_SIZE=1.0
MAX_TRADE_SIZE=3.0
ORDER_TIME_IN_FORCE=fok           # fok | gtc | gtc_first_leg
GTC_ORDER_TIMEOUT=30.0

# ---------------------------------------------------------------------------
# Risk Management
# ---------------------------------------------------------------------------
DAILY_LOSS_LIMIT=5.0
MAX_OPEN_POSITIONS=10
MIN_LIQUIDITY=10.0
MIN_NET_ROI=0
ALLOW_BETTER_REENTRY=true
REENTRY_IMPROVEMENT_THRESHOLD=0.20

# ---------------------------------------------------------------------------
# Dynamic Sizing
# ---------------------------------------------------------------------------
DYNAMIC_SIZING_ENABLED=true
SIZING_AGGRESSIVENESS=0.5

# ---------------------------------------------------------------------------
# Platform Credentials (all required for live trading on each platform)
# ---------------------------------------------------------------------------

# Polymarket (Ethereum private key)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_CHAIN_ID=137
POLYMARKET_PROXY_URL=

# Kalshi (RSA key pair)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=         # Path to RSA .pem file, or use _BASE64
# KALSHI_PRIVATE_KEY_BASE64=     # Alternative: base64-encoded private key
KALSHI_PROXY_URL=

# ---------------------------------------------------------------------------
# Liquidity Rewards (Polymarket + Kalshi LIP/VIP)
# ---------------------------------------------------------------------------
REWARDS_ENABLED=false
REWARDS_MAX_EXPOSURE=200.0
REWARDS_MIN_SIZE=5.0
REWARDS_MAX_SPREAD=0.05
REWARDS_POLL_INTERVAL=60
REWARDS_MIN_RESTING_TIME=300
KALSHI_LIP_ENABLED=false          # Kalshi Liquidity Incentive Program scoring
KALSHI_VIP_TRACK_ENABLED=false    # Kalshi Volume Incentive Program tracking (read-only)
KALSHI_VIP_POLL_INTERVAL=1800     # VIP fills poll interval (seconds)

# Betfair (SSO + API key)
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_API_KEY=
BETFAIR_COMMISSION_RATE=0.03
BETFAIR_PROXY_URL=

# Smarkets
SMARKETS_API_KEY=
SMARKETS_COMMISSION_RATE=0.02
SMARKETS_PROXY_URL=

# SX Bet (read-only — order signing not yet implemented)
SXBET_API_KEY=
SXBET_PRIVATE_KEY=
SXBET_PROXY_URL=

# Matchbook (session auth)
MATCHBOOK_USERNAME=
MATCHBOOK_PASSWORD=
MATCHBOOK_PROXY_URL=

# Gemini Predictions (HMAC-SHA384)
GEMINI_API_KEY=
GEMINI_API_SECRET=
GEMINI_BASE_URL=https://api.gemini.com
GEMINI_FEE_RATE=0.05             # 5% taker / 1% maker
GEMINI_ORDER_TYPE=ioc            # ioc | gtc
GEMINI_PROXY_URL=

# IBKR ForecastEx (IB Gateway socket — BUY-only)
IBKR_HOST=127.0.0.1
IBKR_PORT=4001
IBKR_CLIENT_ID=1

# Metaculus (optional — works without API key)
METACULUS_API_KEY=

# ---------------------------------------------------------------------------
# Dynamic Fee Arbitrage (GasMonitor)
# ---------------------------------------------------------------------------
DYNAMIC_FEE_ENABLED=false
POLYGON_RPC_URL=https://polygon-rpc.com
GAS_PRICE_CACHE_TTL=15.0
POLYGON_GAS_ESTIMATE=0.005

# ---------------------------------------------------------------------------
# Event Monitor (Metaculus divergence signals)
# ---------------------------------------------------------------------------
EVENT_MONITOR_ENABLED=false
EVENT_DIVERGENCE_THRESHOLD=0.10

# ---------------------------------------------------------------------------
# WebSocket Feeds
# ---------------------------------------------------------------------------
WS_TRIGGER_ENABLED=true
WS_TRIGGER_THRESHOLD=0.03
WS_SUBSCRIPTION_LIMIT=2000

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------
WEBHOOK_URL=                     # Slack/Discord/generic webhook URL
WEBHOOK_MIN_PROFIT=0.01

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------
DASHBOARD_PORT=8080
DASHBOARD_USER=admin
DASHBOARD_PASS=                  # Empty = no auth
DASHBOARD_REFRESH_SECONDS=15

# ---------------------------------------------------------------------------
# Data & Persistence
# ---------------------------------------------------------------------------
DATA_DIR=.                       # Directory for trades.db

# ---------------------------------------------------------------------------
# Fee Model
# ---------------------------------------------------------------------------
FEE_MODEL=expected_value         # expected_value | worst_case

# ---------------------------------------------------------------------------
# Semantic Matching
# ---------------------------------------------------------------------------
SEMANTIC_MATCHING_ENABLED=true
SEMANTIC_MATCH_THRESHOLD=0.70

# ---------------------------------------------------------------------------
# Snapshot / Backtesting
# ---------------------------------------------------------------------------
SNAPSHOT_ENABLED=false
SNAPSHOT_INTERVAL=60
BACKTEST_INITIAL_BALANCE=1000.0

# ---------------------------------------------------------------------------
# Metrics & Alerting
# ---------------------------------------------------------------------------
METRICS_ENABLED=true
ALERT_RATE_LIMIT_SECONDS=300
ALERT_LOSS_STREAK_THRESHOLD=5
ALERT_BALANCE_LOW_THRESHOLD=10.0
