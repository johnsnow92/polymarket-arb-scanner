{
  "family": "arb-scanner",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "arb-scanner",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/polymarket-arb-scanner:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "DATA_DIR", "value": "/data" },
        { "name": "DASHBOARD_PORT", "value": "8080" },
        { "name": "DASHBOARD_USER", "value": "jtamm" },
        { "name": "DASHBOARD_REFRESH_SECONDS", "value": "15" },
        { "name": "DRY_RUN", "value": "false" },
        { "name": "EXECUTION_MODE", "value": "full-auto" },
        { "name": "LOG_LEVEL", "value": "INFO" },
        { "name": "MIN_PROFIT_THRESHOLD", "value": "0.005" },
        { "name": "BASE_TRADE_SIZE", "value": "1.0" },
        { "name": "MAX_TRADE_SIZE", "value": "3.0" },
        { "name": "MAX_RESOLUTION_DAYS", "value": "7" },
        { "name": "MAX_OPEN_POSITIONS", "value": "10" },
        { "name": "DAILY_LOSS_LIMIT", "value": "5.0" },
        { "name": "MIN_PROFIT_AMOUNT", "value": "0.02" },
        { "name": "RESCAN_INTERVAL", "value": "60" },
        { "name": "ENABLED_EXECUTION_PLATFORMS", "value": "polymarket,kalshi,sxbet" }
      ],
      "secrets": [
        {
          "name": "POLYMARKET_PRIVATE_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:arb-scanner/polymarket-private-key"
        },
        {
          "name": "KALSHI_API_KEY_ID",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:arb-scanner/kalshi-api-key-id"
        },
        {
          "name": "KALSHI_PRIVATE_KEY_BASE64",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:arb-scanner/kalshi-private-key"
        },
        {
          "name": "GEMINI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:arb-scanner/gemini-api-key"
        },
        {
          "name": "GEMINI_API_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:arb-scanner/gemini-api-secret"
        },
        {
          "name": "DASHBOARD_PASS",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:arb-scanner/dashboard-pass"
        },
        {
          "name": "SXBET_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:arb-scanner/sxbet-api-key"
        },
        {
          "name": "SXBET_PRIVATE_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:arb-scanner/sxbet-private-key"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "efs-data",
          "containerPath": "/data",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/arb-scanner",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "scanner"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8080/healthz')\" || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 120
      }
    }
  ],
  "volumes": [
    {
      "name": "efs-data",
      "efsVolumeConfiguration": {
        "fileSystemId": "EFS_FILE_SYSTEM_ID",
        "rootDirectory": "/",
        "transitEncryption": "ENABLED"
      }
    }
  ]
}
